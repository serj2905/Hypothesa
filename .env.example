# Скопируй в .env и заполни. .env в git НЕ коммитим (см. .gitignore).

# Ollama HTTP-эндпоинт. На 5080-боксе — localhost.
OLLAMA_HOST=http://localhost:11434

# Генератор: интервьюер + суммаризатор (live, Qwen).
LLM_MODEL=qwen2.5:14b-instruct-q4_K_M

# Судья: ДРУГОЕ семейство (batch-фаза). См. sprint_1.md про self-preference bias.
JUDGE_MODEL=llama3.1:8b

LLM_TIMEOUT=120

# Перевыпущенные токены (старые из DHA_hackathon/sets.py — ОТОЗВАТЬ):
TELEGRAM_TOKEN=
